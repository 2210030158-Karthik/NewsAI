# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=personalized_news
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
SECRET_KEY=replace_with_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# News discovery provider
SERPAPI_API_KEY=your_serpapi_api_key

# Feature flags
ENABLE_ASYNC_INGESTION=true
ENABLE_LOCAL_RANKER=false
ENABLE_FEEDBACK_RANKING=false
ENABLE_PERSONALIZED_REPORTS=false
ZERO_SHOT_MODEL_NAME=facebook/bart-large-mnli
LOCAL_CLASSIFIER_MODEL_NAME=valhalla/distilbart-mnli-12-1
CLASSIFIER_MAX_LABEL_TEXT_LENGTH=512
FULL_ARTICLE_MIN_CHARS=300

# Async ingestion tuning
ASYNC_INGESTION_TOPIC_BATCH_SIZE=250
INGESTION_MAX_ARTICLES_PER_TOPIC=10
INGESTION_PROGRESS_UPDATE_EVERY=20

# Celery and Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
